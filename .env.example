# Copy this file to .env.local and fill in your values.
# Never commit .env.local or real keys to Git.

# --- Supabase (required for auth + database) ---
# From your Supabase project: Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# From your Supabase project: Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- OpenAI (server-side only: Vercel / api/* or local server) ---
# Set in Vercel: Project → Settings → Environment Variables
# Or in .env.local when running the dev server that proxies /api
OPENAI_API_KEY=sk-your-openai-key-here
