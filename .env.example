# Copy this file to .env.local and fill in your values.
# Never commit .env.local or real keys to Git.
# Use ONE Supabase project only (all three Supabase values from the same project).

# --- Supabase (required for auth + database + recruiter) ---
# From your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- OpenAI (server-side: Vercel / api/* or local dev server) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Optional: Sentry (production error monitoring) ---
# Create a project at sentry.io → copy DSN. Browser + server are separate client keys in Sentry; use JS browser DSN for VITE_ and Node DSN for server.
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_TRACES_SAMPLE_RATE=0.05

# --- Supabase Auth (configure in dashboard, not in this file) ---
# Authentication → URL configuration: set Site URL to your production app (https://…).
# Add Redirect URLs: production URL + http://localhost:5173 for local dev.

# Optional: OpenAI model for POST /api/aria-coach (default gpt-4o)
# ARIA_COACH_MODEL=gpt-4o-mini

# --- Optional: do NOT put VERCEL_TOKEN here for day-to-day local dev ---
# An old/wrong token breaks `npm run start` ("The specified token is not valid").
# Use `vercel login` once. For UI-only (no /api): `npm run dev:ui-only`.

# --- Optional: advanced — if you use `npm run dev:ui-only` + `npm run api:local` in two terminals ---
# `npm run dev:vite` sets these for you. If you add DEV_API_PROXY_TARGET here, use a real URL — never leave it blank (blank line overwrites nothing now in run-with-env, but avoid confusion).
# DEV_API_PROXY_TARGET=http://127.0.0.1:8787
# LOCAL_API_PORT=8787
